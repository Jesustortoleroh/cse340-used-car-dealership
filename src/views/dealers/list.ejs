<%- include('../partials/header') %>

<main>

  <h1>Dealers</h1>

  <p>
    Sort by:
    <a href="/dealers?sort=name">Name</a> |
    <a href="/dealers?sort=location">Location</a>
  </p>

  <div class="dealer-list">

    <% dealers.forEach(dealer => { %>

      <div class="dealer-card">

        <% if (dealer.image_url) { %>
          <img
            src="<%= dealer.image_url %>"
            alt="<%= dealer.name %>"
            class="dealer-image"
          >
        <% } %>

        <h3>
          <a href="/dealers/<%= dealer.slug %>">
            <%= dealer.name %>
          </a>
        </h3>

        <p>
          <strong>Location:</strong>
          <%= dealer.location %>
        </p>

      </div>

    <% }) %>

  </div>

</main>

<%- include('../partials/footer') %>