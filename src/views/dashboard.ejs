<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <% if (user) { %>

        <div class="dashboard-container">

            <!-- User Profile -->
            <section class="user-profile">

             <h2><%= greeting %></h2>
             
             <p class="dashboard-subtitle">

            <% if (user.roleName === 'customer') { %>
            Browse vehicles, submit service requests, and manage your dealership interactions.
            <% } %>

            <% if (user.roleName === 'employee') { %>
            Manage customer inquiries and service requests.
            <% } %>

            <% if (user.roleName === 'owner') { %>
            Oversee dealership operations and user management.
            <% } %>

           </p>

                <div class="user-details">

                    <div class="detail-item">
                        <span class="label">Name:</span>
                        <span class="value">
                            <%= user.name %>
                        </span>
                    </div>

                    <div class="detail-item">
                        <span class="label">Email:</span>
                        <span class="value">
                            <%= user.email %>
                        </span>
                    </div>

                   <div class="detail-item">
                        <span class="label">Role:</span>
                        <span class="role-badge role-<%= user.roleName %>">
                            <%= user.roleName %>
                        </span>
                    </div>

                    <div class="detail-item">
                        <span class="label">Member Since:</span>
                        <span class="value">
                            <%= new Date(user.created_at).toLocaleDateString() %>
                        </span>
                    </div>

                </div>

            </section>

            <!-- Customer Tools -->
            <section class="dashboard-actions">

                <h2>Customer Tools</h2>

                <ul>

                    <li>
                        <a href="/vehicles">
                            Browse Vehicles
                        </a>
                    </li>

                    <li>
                        <a href="/dealers">
                            View Dealers
                        </a>
                    </li>

                    <li>
                        <a href="/service-requests">
                            Service Requests
                        </a>
                    </li>

                    <li>
                        <a href="/service-requests/create">
                            Submit Service Request
                        </a>
                    </li>

                    <li>
                        <a href="/contact">
                            Contact Dealership
                        </a>
                    </li>

                </ul>

            </section>

            <!-- Employee & Owner Tools -->
            <% if (
                user.roleName === 'employee' ||
                user.roleName === 'owner'
            ) { %>

                <section class="dashboard-actions">

                    <h2>Staff Tools</h2>

                    <ul>

                        <li>
                            <a href="/contact/responses">
                                View Contact Responses
                            </a>
                        </li>

                        <li>
                            <a href="/service-requests">
                                Manage Service Requests
                            </a>
                        </li>

                    </ul>

                </section>

            <% } %>

            <!-- Owner Tools -->
            <% if (user.roleName === 'owner') { %>

                <section class="dashboard-actions">

                    <h2>Administration</h2>

                    <ul>

                        <li>
                            <a href="/register/list">
                                Manage Users
                            </a>
                        </li>

                    </ul>

                </section>

            <% } %>

        </div>

    <% } else { %>

        <p>
            Please log in to view your dashboard.
        </p>

    <% } %>

</main>

<%- include('partials/footer') %>