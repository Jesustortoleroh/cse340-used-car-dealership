<%- include('../../partials/header') %>

<main>

    <h1><%= title %></h1>

    <p>
        Below is a list of registered customers who have created
        accounts with our dealership.
    </p>

    <!-- Mostrar mensajes flash -->
    <% if (flash) { %>
        <% if (flash.error) { %>
            <div class="flash error">
                <%= flash.error %>
            </div>
        <% } %>
        <% if (flash.success) { %>
            <div class="flash success">
                <%= flash.success %>
            </div>
        <% } %>
    <% } %>

    <% if (users && users.length > 0) { %>

        <div class="users-list">

            <% users.forEach(listUser => { %>
                <% 
                    // Calculate permissions for this user card
                    // 'user' variable contains the current logged-in user (from session)
                    // 'listUser' is the user from the users array we're currently rendering
                    const currentUser = typeof user !== 'undefined' && user ? user : null;
                    const canEdit = currentUser && (currentUser.id === listUser.id || currentUser.roleName === 'owner');
                    const canDelete = currentUser && currentUser.roleName === 'owner' && currentUser.id !== listUser.id;
                %>

                <div class="user-card">

                    <div class="user-header">

                        <h3>
                            <%= listUser.name %>
                        </h3>

                        <span class="user-id">
                            ID: <%= listUser.id %>
                        </span>

                    </div>

                    <div class="user-details">

                        <div class="detail-item">

                            <div class="label">
                                Email
                            </div>

                            <div class="value">
                                <%= listUser.email %>
                            </div>

                        </div>

                        <% if (listUser.roleName) { %>

                            <div class="detail-item">

                                <div class="label">
                                    Role
                                </div>

                                <div class="value">
                                    <span class="role-badge role-<%= listUser.roleName %>">
                                        <%= listUser.roleName %>
                                    </span>
                                </div>

                            </div>

                        <% } %>

                        <div class="detail-item">

                            <div class="label">
                                Registered
                            </div>

                            <div class="value">
                                <%= new Date(listUser.created_at).toLocaleDateString() %>
                            </div>

                        </div>

                    </div>

                    <!-- User Actions - Only shown if user has permissions -->
                    <% if (canEdit || canDelete) { %>
                        <div class="user-actions">
                            <% if (canEdit) { %>
                                <a href="/register/<%= listUser.id %>/edit" class="btn-edit">
                                    ✏️ Edit
                                </a>
                            <% } %>
                            <% if (canDelete) { %>
                                <form method="POST" action="/register/<%= listUser.id %>/delete" style="display: inline;">
                                    <button 
                                        type="submit" 
                                        class="btn-delete" 
                                        onclick="return confirm('Are you sure you want to delete this user? This action cannot be undone.')"
                                    >
                                        🗑️ Delete
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    <% } %>

                </div>

            <% }); %>

        </div>

    <% } else { %>

        <p class="no-users">
            No customers have registered yet.
        </p>

    <% } %>

    <div class="page-actions">
        <a href="/register" class="btn-primary">
            Create Another Account
        </a>
        <a href="/dashboard" class="btn-secondary">
            Back to Dashboard
        </a>
    </div>

</main>

<%- include('../../partials/footer') %>