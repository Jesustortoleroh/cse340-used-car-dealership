<%- include('../../partials/header') %>

<main>

    <section class="account-edit">

        <h1><%= title %></h1>

        <p class="text-muted">
            Update your dealership account information below.
        </p>

        <form
            method="POST"
            action="/register/<%= user.id %>/edit"
            class="account-form"
        >

            <div class="form-group">

                <label for="name">
                    Full Name
                </label>

                <input
                    type="text"
                    id="name"
                    name="name"
                    value="<%= user.name %>"
                    required
                    minlength="2"
                    maxlength="100"
                    pattern="[a-zA-Z\s'-]+"
                    title="Letters, spaces, hyphens, and apostrophes only"
                >

                <small class="help-text">
                    Between 2 and 100 characters.
                </small>

            </div>

            <div class="form-group">

                <label for="email">
                    Email Address
                </label>

                <input
                    type="email"
                    id="email"
                    name="email"
                    value="<%= user.email %>"
                    required
                    maxlength="255"
                >

                <small class="help-text">
                    Enter a valid email address.
                </small>

            </div>

            <div class="form-actions">

                <button
                    type="submit"
                    class="btn-primary"
                >
                    Update Account
                </button>

                <a
                    href="/register/list"
                    class="btn-secondary"
                >
                    Cancel
                </a>

            </div>

        </form>

    </section>

</main>

<%- include('../../partials/footer') %>