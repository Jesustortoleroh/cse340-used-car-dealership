<%- include('../../partials/header') %>

<main>
    <h1>Contact Our Dealership</h1>

    <p>
        Have questions about a vehicle, financing options, or scheduling a test drive?
        Send us a message and our team will get back to you as soon as possible.
    </p>

    <form method="POST" action="/contact" class="contact-form">

        <div class="form-group">
            <label for="customer_name">Your Name</label>
            <input
                type="text"
                id="customer_name"
                name="customer_name"
                placeholder="Enter your full name"
                minlength="2"
                required>
        </div>

        <div class="form-group">
            <label for="email">Email Address</label>
            <input
                type="email"
                id="email"
                name="email"
                placeholder="your@email.com"
                required>
        </div>

        <div class="form-group">
            <label for="phone">Phone Number</label>
            <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(555) 123-4567"
                minlength="7"
                maxlength="20"
                required>
        </div>

        <div class="form-group">
            <label for="subject">Subject</label>
            <input
                type="text"
                id="subject"
                name="subject"
                placeholder="Vehicle inquiry, financing, appointment..."
                minlength="2"
                required>
        </div>

        <div class="form-group">
            <label for="message">Message</label>
            <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="Tell us how we can help you..."
                minlength="10"
                required></textarea>
        </div>

        <button type="submit">
            Send Inquiry
        </button>

    </form>

    <p class="contact-link">
        <a href="/contact/responses">
            View Customer Inquiries
        </a>
    </p>
</main>

<%- include('../../partials/footer') %>