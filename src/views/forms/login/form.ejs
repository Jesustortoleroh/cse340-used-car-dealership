<%- include('../../partials/header') %>

<main>

    <h1><%= title %></h1>

    <p>
        Sign in to access your dealership account, manage your profile,
        view service requests, and interact with our vehicle inventory.
        Don't have an account yet?
        <a href="/register">Create one here</a>.
    </p>

    <form
        method="POST"
        action="/login"
        class="login-form"
    >

        <!-- Email -->

        <div class="form-group">

            <label for="email">
                Email Address
            </label>

            <input
                type="email"
                id="email"
                name="email"
                placeholder="Enter your email address"
                maxlength="255"
                required
                autocomplete="email"
            >

        </div>

        <!-- Password -->

        <div class="form-group">

            <label for="password">
                Password
            </label>

            <input
                type="password"
                id="password"
                name="password"
                minlength="8"
                maxlength="128"
                placeholder="Enter your password"
                required
                autocomplete="current-password"
            >

        </div>

        <!-- Submit -->

        <button
            type="submit"
            class="btn-primary"
        >
            Sign In
        </button>

        <div class="form-footer">

            <p>
                New customer?
                <a href="/register">
                    Create an account
                </a>
            </p>

        </div>

    </form>

</main>

<%- include('../../partials/footer') %>