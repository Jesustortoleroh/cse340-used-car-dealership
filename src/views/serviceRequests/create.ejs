<%- include('../partials/header') %>

<main>

    <h1><%= title %></h1>

    <!-- Show flash messages -->
    <% if (flash) { %>
        <% if (flash.error) { %>
            <div class="flash error">
                <%= flash.error %>
            </div>
        <% } %>
        <% if (flash.success) { %>
            <div class="flash success">
                <%= flash.success %>
            </div>
        <% } %>
    <% } %>

    <form
        action="/service-requests/create"
        method="POST"
        class="service-form"
    >

        <div class="form-group">

            <label for="service_type_id">
                Service Type <span class="text-danger">*</span>
            </label>

            <select
                id="service_type_id"
                name="service_type_id"
                class="form-control"
                required
            >

                <option value="">
                    Select a service type...
                </option>

                <% if (serviceTypes && serviceTypes.length > 0) { %>

                    <% serviceTypes.forEach(type => { %>

                        <option
                            value="<%= type.id %>"
                            <%= formData?.service_type_id == type.id
                                ? 'selected'
                                : '' %>
                        >
                            <%= type.name %>
                        </option>

                    <% }) %>

                <% } else { %>

                    <option value="" disabled>
                        No service types available
                    </option>

                <% } %>

            </select>

        </div>

        <div class="form-group">

            <label for="vehicle_id">
                Vehicle <span class="text-danger">*</span>
            </label>

            <select
                id="vehicle_id"
                name="vehicle_id"
                class="form-control"
                required
            >

                <option value="">
                    Select a vehicle...
                </option>

                <% if (vehicles && vehicles.length > 0) { %>

                    <% vehicles.forEach(vehicle => { %>

                        <option
                            value="<%= vehicle.id %>"
                            <%= formData?.vehicle_id == vehicle.id
                                ? 'selected'
                                : '' %>
                        >
                            <%= vehicle.name %> -
                            $<%= vehicle.price.toLocaleString() %>
                        </option>

                    <% }) %>

                <% } else { %>

                    <option value="" disabled>
                        No vehicles available
                    </option>

                <% } %>

            </select>

        </div>

        <div class="form-group">

            <label for="description">
                Description <span class="text-danger">*</span>
            </label>

            <textarea
                id="description"
                name="description"
                rows="5"
                class="form-control"
                required
            ><%= formData?.description || '' %></textarea>

        </div>

        <div class="request-actions">

            <a href="/service-requests" class="btn-secondary">
                ← Back to Requests
            </a>

            <button
                type="submit"
                class="btn-primary"
            >
                Submit Request
            </button>

        </div>

    </form>

</main>

<%- include('../partials/footer') %>