<%- include('../partials/header') %>

<main>

    <!-- show flash messages -->
    <% if (flash) { %>
        <% if (flash.error) { %>
            <div class="flash error">
                <%= flash.error %>
            </div>
        <% } %>
        <% if (flash.success) { %>
            <div class="flash success">
                <%= flash.success %>
            </div>
        <% } %>
    <% } %>

    <div class="page-header">
        <h1><%= title %></h1>
        <a href="/service-requests/create" class="btn-primary">
            + Create Service Request
        </a>
    </div>

    <% if (requests && requests.length > 0) { %>

        <div class="request-list">

            <% requests.forEach(request => { %>

                <article class="request-card">

                    <div class="request-header">
                        <h3>
                            <%= request.service_type_name || request.service_type || 'Service Request' %>
                        </h3>
                        <span class="status-badge status-<%= request.status.toLowerCase().replace(' ', '-') %>">
                            <%= request.status %>
                        </span>
                    </div>

                    <div class="request-body">

                        <p class="request-description">
                            <strong>Description:</strong>
                            <%= request.description %>
                        </p>

                        <% if (request.vehicle_name) { %>
                            <p>
                                <strong>Vehicle:</strong>
                                <%= request.vehicle_name %>
                            </p>
                        <% } %>

                        <% if (request.customer_name) { %>
                            <p>
                                <strong>Customer:</strong>
                                <%= request.customer_name %>
                            </p>
                        <% } %>

                        <% if (request.created_at) { %>
                            <p>
                                <strong>Date:</strong>
                                <%= new Date(request.created_at).toLocaleDateString('en-US', { 
                                    year: 'numeric', 
                                    month: 'short', 
                                    day: 'numeric' 
                                }) %>
                            </p>
                        <% } %>

                    </div>

                    <div class="request-actions">
                        <a href="/service-requests/<%= request.id %>/edit" class="btn-edit">
                            ✏️ Edit
                        </a>

                        <form action="/service-requests/<%= request.id %>/delete" method="POST" class="delete-form">
                            <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this service request?')">
                                🗑️ Delete
                            </button>
                        </form>
                    </div>

                </article>

            <% }) %>

        </div>

    <% } else { %>

        <div class="empty-state">
            <span class="empty-icon">🔧</span>
            <p>No service requests found.</p>
            <p class="empty-sub">Create your first service request to get started!</p>
            <a href="/service-requests/create" class="btn-primary" style="margin-top: 1rem;">
                Create Service Request
            </a>
        </div>

    <% } %>

</main>

<%- include('../partials/footer') %>