<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>

  <p>
    Browse our available vehicles and click on any car to view detailed
    specifications and pricing.
  </p>

  
  <div class="category-filter">
    <span>Browse by category: </span>

    <a href="/vehicles"
       class="<%= currentCategory === 'All' ? 'active' : '' %>">
      All
    </a>

    <a href="/vehicles?category=Car"
       class="<%= currentCategory === 'Car' ? 'active' : '' %>">
      Cars
    </a>

    <a href="/vehicles?category=SUV"
       class="<%= currentCategory === 'SUV' ? 'active' : '' %>">
      SUVs
    </a>

    <a href="/vehicles?category=Truck"
       class="<%= currentCategory === 'Truck' ? 'active' : '' %>">
      Trucks
    </a>
  </div>

  <!-- ✅ VEHICLE LIST -->
  <div class="vehicle-list">

    <% vehicles.forEach(vehicle => { %>
      <div class="vehicle-card">

        <h3>
          <a href="/vehicles/<%= vehicle.id %>">
            <%= vehicle.name %>
          </a>
        </h3>

        <p class="vehicle-id">
          $<%= vehicle.price %>
        </p>

        <p class="vehicle-description">
          <%= vehicle.description %>
        </p>

      </div>
    <% }); %>

  </div>

</main>

<%- include('partials/footer') %>