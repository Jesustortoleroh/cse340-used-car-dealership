<%- include('../partials/header') %>

<main class="error-page" role="main">
    <div class="error-icon">🚗</div>

    <h1>404 - Page Not Found</h1>

    <p class="error-message">
        The page you are looking for does not exist or may have been moved.
    </p>

    <img src="/images/404-car.png" 
        alt="Vehicle dealership 404 error illustration" 
        loading="lazy">

    <div class="error-actions">
        <a href="/" class="btn-primary">Return Home</a>

        <a href="/vehicles" class="btn-secondary">Browse Vehicles</a>

        <% if (user) { %>
            <a href="/dashboard" class="btn-secondary">Dashboard</a>
        <% } %>
    </div>
</main>

<%- include('../partials/footer') %>
