<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/error.css">
    <%- renderStyles() %>
    <%- renderScripts() %>

    <% if (NODE_ENV.includes('dev')) { %>
    <script>
        // Get the current hostname and port from the browser
        const host = window.location.hostname;
        const currentPort = window.location.port;

        // Calculate WebSocket port (current port + 1)
        const wsPort = currentPort ? (parseInt(currentPort) + 1) : 3001;

        // Create WebSocket connection using dynamic hostname and port
        const ws = new WebSocket(`ws://${host}:${wsPort}`);
        ws.onclose = () => {
            setTimeout(() => location.reload(), 2000);
        };
    </script>
    <% } %>
</head>
<body>
    <!-- Main navigation header -->
    <header>
        <nav class="main-nav">
            <div class="nav-top">
              
                <!-- Mobile menu toggle button -->
                <button
                    class="menu-toggle"
                    id="menu-toggle"
                    aria-label="Toggle navigation"
                >
                    ☰
                </button>
            </div>

            <!-- Navigation menu list -->
            <ul id="nav-menu">
                <!-- Always visible links -->
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/vehicles">Vehicles</a></li>
                <li><a href="/dealers">Dealers</a></li>
                <li><a href="/contact">Contact</a></li>

                <!-- Conditional content for logged-in users -->
                <% if (isLoggedIn) { %>
                    <!-- Dashboard link -->
                    <li><a href="/dashboard">Dashboard</a></li>

                    <!-- Conditional content for employee or owner roles -->
                    <% if (user && (user.roleName === 'employee' || user.roleName === 'owner')) { %>
                        <!-- Vehicle registration list link -->
                        <li><a href="/register/list">Register List</a></li>
                        <!-- Inquiries link -->
                        <li><a href="/responses">Inquiries</a></li>
                    <% } %>

                    <!-- Logout link -->
                    <li><a href="/logout">Logout</a></li>

                <% } else { %>
                    <!-- Login link for non-authenticated users -->
                    <li><a href="/login">Login</a></li>
                    <!-- Registration link -->
                    <li><a href="/register">Create Account</a></li>
                <% } %>
            </ul>
        </nav>
    </header>

    <!-- Flash messages display -->
    <%
    const messages =
        typeof flash === 'function'
            ? flash()
            : {
                success: [],
                error: [],
                warning: [],
                info: []
            };

    const hasMessages =
        Object.values(messages)
            .some(arr => arr.length > 0);
    %>

    <% if (hasMessages) { %>
        <div class="flash-messages">
            <% Object.keys(messages).forEach(type => { %>
                <% messages[type].forEach(message => { %>
                    <div class="flash <%= type %>">
                        <%= message %>
                    </div>
                <% }); %>
            <% }); %>
        </div>
    <% } %>

    <!-- JavaScript files -->
    <script src="/js/navigation.js"></script>
</body>
</html>