<%- include('../partials/header') %>

<main>

    <div class="vehicle-header">

        <h1><%= vehicle.name %></h1>

        <% if (vehicle.image_url) { %>
            <img
                src="<%= vehicle.image_url %>"
                class="vehicle-detail-image"
                alt="<%= vehicle.name %>"
            >
        <% } %>

        <p class="vehicle-category">
            Category: <%= vehicle.category %>
        </p>

        <p class="vehicle-meta">
            $<%= vehicle.price.toLocaleString() %>
        </p>

        <p class="vehicle-description">
            <%= vehicle.description %>
        </p>

        <% if (vehicle.dealer) { %>
            <p class="vehicle-dealer">
                Dealer:
                <a href="/dealers/<%= vehicle.dealer_slug %>" class="dealer-link">
                    <%= vehicle.dealer %>
                </a>
                • <%= vehicle.location %>
            </p>
        <% } %>

    </div>

    <section class="specs">

        <div class="sections-header">

            <h2>Specifications</h2>

            <div class="sort-options">

                <span>Sort by:</span>

                <a href="/vehicles/<%= vehicle.slug %>?sort=feature"
                    class="<%= currentSort === 'feature' ? 'active' : '' %>"
                >
                    Feature
                </a>

                <a href="/vehicles/<%= vehicle.slug %>?sort=value"
                    class="<%= currentSort === 'value' ? 'active' : '' %>"
                >
                    Value
                </a>

            </div>

        </div>

        <div class="specs-list">

            <% if (vehicle.specs && vehicle.specs.length > 0) { %>

                <% vehicle.specs.forEach(spec => { %>

                    <div class="spec-card">

                        <strong>
                            <%= spec.feature %>:
                        </strong>

                        <span>
                            <%= spec.value %>
                        </span>

                    </div>

                <% }) %>

            <% } else { %>

                <p>No specifications available.</p>

            <% } %>

        </div>

    </section>

    <!-- Reviews Section -->
    <section class="reviews-section">

        <div class="reviews-header">
            <h2>Customer Reviews</h2>
            <% if (reviews && reviews.length > 0) { %>
                <div class="reviews-summary-badge">
                    <span class="avg-rating"><%= averageRating %></span>
                    <div class="mini-stars">
                        <% for(let i = 0; i < 5; i++) { %>
                            <% if(i < Math.round(averageRating)) { %>
                                <span class="star filled">★</span>
                            <% } else { %>
                                <span class="star">★</span>
                            <% } %>
                        <% } %>
                    </div>
                    <span class="review-count">(<%= reviews.length %> reviews)</span>
                </div>
            <% } %>
        </div>

        <% if (reviews && reviews.length > 0) { %>

            <!-- Rating Breakdown -->
            <div class="rating-breakdown">
                <% for(let i = 5; i >= 1; i--) { %>
                    <% const percentage = ratingPercentages ? ratingPercentages[i] : 0; %>
                    <div class="breakdown-row">
                        <span class="stars-label"><%= i %> star</span>
                        <div class="progress-bar">
                            <div class="progress-fill" data-width="<%= percentage %>"></div>
                        </div>
                        <span class="percentage"><%= percentage %>%</span>
                    </div>
                <% } %>
            </div>

            <!-- Reviews List -->
            <div class="reviews-list">
                <% reviews.forEach(review => { %>
                    <article class="review-card">
                        <div class="review-header">
                            <h3><%= review.name %></h3>
                            <div class="review-stars">
                                <% for(let i = 0; i < 5; i++) { %>
                                    <% if(i < review.rating) { %>
                                        <span class="star filled">★</span>
                                    <% } else { %>
                                        <span class="star">★</span>
                                    <% } %>
                                <% } %>
                            </div>
                            <small class="review-date">
                                <%= new Date(review.created_at).toLocaleDateString('en-US', { 
                                    year: 'numeric', 
                                    month: 'short', 
                                    day: 'numeric' 
                                }) %>
                            </small>
                        </div>

                        <p class="review-comment"><%= review.comment %></p>

                        <% if (user && (user.id === review.user_id || user.roleName === 'employee' || user.roleName === 'owner')) { %>
                            <div class="review-actions">
                                <a href="/reviews/<%= review.id %>/edit" class="btn-edit">
                                    ✏️ Edit
                                </a>
                                <form action="/reviews/<%= review.id %>/delete" method="POST" class="delete-form">
                                    <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this review?')">
                                        🗑️ Delete
                                    </button>
                                </form>
                            </div>
                        <% } %>
                    </article>
                <% }) %>
            </div>

        <% } else { %>

            <div class="empty-state">
                <span class="empty-icon">🚗</span>
                <p>No reviews have been submitted yet for this vehicle.</p>
                <p class="empty-sub">Be the first to share your experience!</p>
            </div>

        <% } %>

    </section>

    <!-- Leave Review -->
    <% if (user) { %>

        <section class="review-form-section">

            <h2>Leave a Review</h2>

            <!-- Mostrar mensajes flash -->
            <% if (flash) { %>
                <% if (flash.error) { %>
                    <div class="flash error">
                        <%= flash.error %>
                    </div>
                <% } %>
                <% if (flash.success) { %>
                    <div class="flash success">
                        <%= flash.success %>
                    </div>
                <% } %>
            <% } %>

            <form action="/reviews/create" method="POST" class="review-form">

                <input
                    type="hidden"
                    name="vehicle_id"
                    value="<%= vehicle.id %>"
                >

                <div class="form-group">

                    <label>
                        Rating <span class="text-danger">*</span>
                    </label>

                    <div class="star-rating">

                        <input
                            type="radio"
                            id="star5"
                            name="rating"
                            value="5"
                            required
                        >
                        <label for="star5">★</label>

                        <input
                            type="radio"
                            id="star4"
                            name="rating"
                            value="4"
                        >
                        <label for="star4">★</label>

                        <input
                            type="radio"
                            id="star3"
                            name="rating"
                            value="3"
                        >
                        <label for="star3">★</label>

                        <input
                            type="radio"
                            id="star2"
                            name="rating"
                            value="2"
                        >
                        <label for="star2">★</label>

                        <input
                            type="radio"
                            id="star1"
                            name="rating"
                            value="1"
                        >
                        <label for="star1">★</label>

                    </div>

                    <!-- Mostrar error de flash debajo de las estrellas -->
                    <% if (flash?.error && !formData?.rating) { %>
                        <div class="invalid-feedback d-block">
                            <%= flash.error %>
                        </div>
                    <% } %>

                </div>

                <div class="form-group">

                    <label for="comment">
                        Review <span class="text-danger">*</span>
                    </label>

                    <textarea
                        id="comment"
                        name="comment"
                        rows="5"
                        class="form-control"
                        required
                    ><%= formData?.comment || '' %></textarea>

                    <!-- Mostrar error de flash debajo del comentario -->
                    <% if (flash?.error && !formData?.comment) { %>
                        <div class="invalid-feedback d-block">
                            <%= flash.error %>
                        </div>
                    <% } %>

                </div>

                <div class="review-actions">

                    <a href="/vehicles" class="btn-secondary">
                        ← Back to Vehicles
                    </a>

                    <button
                        type="submit"
                        class="btn-primary"
                    >
                        Submit Review
                    </button>

                </div>

            </form>

        </section>

    <% } else { %>

        <div class="login-prompt">
            <p>
                <a href="/login" class="login-link">Login</a> to leave a review.
            </p>
        </div>

    <% } %>

    <div class="navigation">

        <a href="/vehicles<%= vehicle.category ? '?category=' + vehicle.category : '' %>">
            ← Back to Vehicles
        </a>

    </div>

</main>

<%- include('../partials/footer') %>
