<%- include('../partials/header') %>

<main>

  <div class="vehicle-header">

    <h1><%= vehicle.name %></h1>

    <% if (vehicle.image_url) { %>
      <img
        src="<%= vehicle.image_url %>"
        alt="<%= vehicle.name %>"
        class="vehicle-detail-image"
      >
    <% } %>

    <p class="vehicle-category">
      Category: <%= vehicle.category %>
    </p>

    <p class="vehicle-meta">
      $<%= vehicle.price.toLocaleString() %>
    </p>

    <p class="vehicle-description">
      <%= vehicle.description %>
    </p>

    <% if (vehicle.dealer) { %>
      <p class="vehicle-dealer">
        Dealer: <%= vehicle.dealer %> • <%= vehicle.location %>
      </p>
    <% } %>

  </div>

  <div class="specs">

    <div class="sections-header">

      <h2>Specifications</h2>

      <div class="sort-options">

        <span>Sort by:</span>

        <a
          href="/vehicles/<%= vehicle.slug %>?sort=feature"
          class="<%= currentSort === 'feature' ? 'active' : '' %>"
        >
          Feature
        </a>

        <a
          href="/vehicles/<%= vehicle.slug %>?sort=value"
          class="<%= currentSort === 'value' ? 'active' : '' %>"
        >
          Value
        </a>

      </div>

    </div>

    <div class="specs-list">

      <% if (vehicle.specs && vehicle.specs.length > 0) { %>

        <% vehicle.specs.forEach(spec => { %>

          <div class="spec-card">
            <strong><%= spec.feature %>:</strong>
            <span><%= spec.value %></span>
          </div>

        <% }) %>

      <% } else { %>

        <p>No specifications available.</p>

      <% } %>

    </div>

  </div>
<section class="reviews-section">

    <h2>Customer Reviews</h2>

    <% if (reviews && reviews.length > 0) { %>

        <% reviews.forEach(review => { %>

            <article class="review-card">

                <h3>
                    <%= review.name %>
                </h3>

                <p>
                    Rating:
                    <strong>
                        <%= review.rating %>/5
                    </strong>
                </p>

                <p>
                    <%= review.comment %>
                </p>

                <small>
                    <%= new Date(review.created_at).toLocaleDateString() %>
                </small>

                <% if (
                    user &&
                    (
                        user.id === review.user_id ||
                        user.roleName === 'employee' ||
                        user.roleName === 'owner'
                    )
                ) { %>

                    <div class="review-actions">

                        edit">
                            Edit
                        </a>

                        %= review.id %>/delete"
                            method="POST"
                        >
                            <button type="submit">
                                Delete
                            </button>
                        </form>

                    </div>

                <% } %>

            </article>

        <% }) %>

    <% } else { %>

        <p>No reviews have been submitted yet.</p>

    <% } %>

</section>

<% if (user) { %>

<section class="create-review">

    <h2>Leave a Review</h2>

    /create"
        method="POST"
    >

        <input
            type="hidden"
            name="vehicle_id"
            value="<%= vehicle.id %>"
        >

        <div class="form-group">

            <label for="rating">
                Rating
            </label>

            <select
                id="rating"
                name="rating"
                required
            >
                <option value="5">5 Stars</option>
                <option value="4">4 Stars</option>
                <option value="3">3 Stars</option>
                <option value="2">2 Stars</option>
                <option value="1">1 Star</option>
            </select>

        </div>

        <div class="form-group">

            <label for="comment">
                Review
            </label>

            <textarea
                id="comment"
                name="comment"
                rows="5"
                required
            ></textarea>

        </div>

        <button type="submit">
            Submit Review
        </button>

    </form>

</section>

<% } else { %>

<p>
    /login
    to leave a review.
</p>

<% } %>
  <div class="navigation">

    <a href="/vehicles<%= vehicle.category ? '?category=' + vehicle.category : '' %>">
      &larr; Back to Vehicles
    </a>

  </div>

</main>

<%- include('../partials/footer') %>

