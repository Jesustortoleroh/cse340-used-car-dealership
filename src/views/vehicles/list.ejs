<%- include('../partials/header') %>

<main>

    <% if (flash) { %>

        <% if (flash.error) { %>
            <div class="flash error">
                <%= flash.error %>
            </div>
        <% } %>

        <% if (flash.success) { %>
            <div class="flash success">
                <%= flash.success %>
            </div>
        <% } %>

    <% } %>

    <h1><%= title %></h1>

    <!-- ==========================================
         Vehicle Search Toolbar - One Line Layout
    ========================================== -->
    <div class="vehicles-toolbar">
        <form action="/vehicles" method="GET" class="vehicle-search-form">
            <!-- Search input -->
            <input 
                type="text" 
                name="search" 
                placeholder="🔍 Search vehicles by name or description..."
                value="<%= queryParams && queryParams.search ? queryParams.search : '' %>"
                class="search-input"
            >

            <!-- Category filter -->
            <select name="category" class="category-select">
                <option value="All" <%= currentCategory === 'All' ? 'selected' : '' %>>
                    All Categories
                </option>
                <option value="Car" <%= currentCategory === 'Car' ? 'selected' : '' %>>
                    Cars
                </option>
                <option value="SUV" <%= currentCategory === 'SUV' ? 'selected' : '' %>>
                    SUVs
                </option>
                <option value="Truck" <%= currentCategory === 'Truck' ? 'selected' : '' %>>
                    Trucks
                </option>
                <option value="Luxury" <%= currentCategory === 'Luxury' ? 'selected' : '' %>>
                    Luxury
                </option>
                <option value="Electric" <%= currentCategory === 'Electric' ? 'selected' : '' %>>
                    Electric
                </option>
            </select>

            <!-- Sort filter -->
            <select name="sort" class="sort-select">
                <option value="name_asc" <%= queryParams && queryParams.sort === 'name_asc' ? 'selected' : '' %>>
                    Sort By
                </option>
                <option value="price_asc" <%= queryParams && queryParams.sort === 'price_asc' ? 'selected' : '' %>>
                    Price: Low to High
                </option>
                <option value="price_desc" <%= queryParams && queryParams.sort === 'price_desc' ? 'selected' : '' %>>
                    Price: High to Low
                </option>
                <option value="name_asc" <%= queryParams && queryParams.sort === 'name_asc' ? 'selected' : '' %>>
                    Name: A to Z
                </option>
                <option value="name_desc" <%= queryParams && queryParams.sort === 'name_desc' ? 'selected' : '' %>>
                    Name: Z to A
                </option>
                <option value="newest" <%= queryParams && queryParams.sort === 'newest' ? 'selected' : '' %>>
                    Newest First
                </option>
            </select>

            <!-- Search button -->
            <button type="submit" class="btn-search">
                Search
            </button>

            <!-- Clear button (only shows when searching or filtering) -->
            <% if ((queryParams && queryParams.search) || (queryParams && queryParams.category && queryParams.category !== 'All') || (queryParams && queryParams.sort && queryParams.sort !== 'name_asc')) { %>
                <a href="/vehicles" class="btn-clear">
                    ✕ Clear
                </a>
            <% } %>
        </form>
    </div>

    <!-- Results count with sort info -->
    <p class="results-count">
        Showing <strong><%= vehicleCount %></strong> <%= vehicleCount === 1 ? 'vehicle' : 'vehicles' %>
        <% if (queryParams && queryParams.search) { %>
            matching "<%= queryParams.search %>"
        <% } %>
        <% if (currentCategory && currentCategory !== 'All') { %>
            in <strong><%= currentCategory %></strong>
        <% } %>
        <% if (queryParams && queryParams.sort && queryParams.sort !== 'name_asc') { %>
            <span class="sort-indicator">
                • Sorted by: <strong><%= sortLabel %></strong>
            </span>
        <% } %>
    </p>

    <!-- Vehicle Grid -->
    <% if (vehicles && vehicles.length > 0) { %>

        <div class="vehicle-list">

            <% vehicles.forEach(vehicle => { %>

                <div class="vehicle-card">

                    <% if (vehicle.image_url) { %>

                        <img src="<%= vehicle.image_url %>"
                            alt="<%= vehicle.name %>"
                            class="vehicle-image"
                        >

                    <% } %>

                    <div class="vehicle-info">

                        <h3>
                            <a href="/vehicles/<%= vehicle.slug %>">
                                <%= vehicle.name %>
                            </a>
                        </h3>

                        <p class="vehicle-price">
                            $<%= vehicle.price.toLocaleString() %>
                        </p>

                        <p class="vehicle-category">
                            Category: <%= vehicle.category %>
                        </p>

                        <% if (vehicle.average_rating) { %>

                            <div class="vehicle-rating">

                                <% for(let i = 0; i < 5; i++) { %>

                                    <% if(i < Math.round(vehicle.average_rating)) { %>

                                        <span class="star filled">
                                            ★
                                        </span>

                                    <% } else { %>

                                        <span class="star">
                                            ★
                                        </span>

                                    <% } %>

                                <% } %>

                                <span class="rating-count">
                                    (<%= vehicle.review_count || 0 %>)
                                </span>

                            </div>

                        <% } %>

                        <!-- View Details button - Now a blue button -->
                        <a href="/vehicles/<%= vehicle.slug %>" class="btn-view-details">
                            View Details →
                        </a>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } else { %>

        <div class="empty-state">

            <span class="empty-icon">
                🚗
            </span>

            <p>
                <% if (queryParams && queryParams.search) { %>
                    No vehicles found matching "<%= queryParams.search %>".
                <% } else { %>
                    No vehicles available in this category.
                <% } %>
            </p>

            <p class="empty-sub">
                <% if (queryParams && queryParams.search) { %>
                    Try adjusting your search terms or browse all vehicles.
                    <br>
                    <a href="/vehicles" class="view-all-link">View all vehicles</a>
                <% } else { %>
                    Check back later for new inventory!
                <% } %>
            </p>

        </div>

    <% } %>

</main>

<%- include('../partials/footer') %>